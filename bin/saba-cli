#!/usr/bin/env bash
# Thin launcher so you can run saba-cli without installing the package.
# It makes `src/` importable and delegates to the Python entry point.
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$SCRIPT_DIR/.." && pwd)"

export PYTHONPATH="${REPO_ROOT}/src${PYTHONPATH:+:${PYTHONPATH}}"

PY="${SABA_CLI_PYTHON:-python3}"
exec "$PY" -m saba_cli "$@"
